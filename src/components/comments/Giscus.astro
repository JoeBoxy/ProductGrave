---
// Giscus comment system — powered by GitHub Discussions
// Setup: https://giscus.app/
//
// After enabling Discussions on your repo, visit giscus.app and fill in:
// - repo: your-username/ProductGrave
// - category: "General" (or create "Grave Discussions")
// - mapping: "pathname"
//
// Then replace the data-repo and data-category-id below with your values.

interface Props {
  term?: string;
}

const { term } = Astro.props;
---

<section class="mt-12">
  <div class="grave-divider mb-6">
    <span class="font-pixel text-xs text-grave-ash whitespace-nowrap">💬 DISCUSSION</span>
  </div>
  <div class="pixel-card p-4 md:p-6">
    <p class="text-sm text-grave-ash mb-4">
      Have a different take on this death? Know an insider detail we missed?
      Drop a comment below.
    </p>
    <div class="giscus"></div>
    <script
      src="https://giscus.app/client.js"
      data-repo="JoeBoxy/ProductGrave"
      data-repo-id="TO_BE_FILLED"
      data-category="General"
      data-category-id="TO_BE_FILLED"
      data-mapping={term ? "specific" : "pathname"}
      data-term={term}
      data-strict="0"
      data-reactions-enabled="1"
      data-emit-metadata="0"
      data-input-position="bottom"
      data-theme="dark"
      data-lang="en"
      data-loading="lazy"
      crossorigin="anonymous"
      async
    ></script>
  </div>
</section>

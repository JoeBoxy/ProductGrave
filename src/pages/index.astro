---
import BaseLayout from '../layouts/BaseLayout.astro';
import TombstoneCard from '../components/tombstone/TombstoneCard.astro';
import GraveStats from '../components/tombstone/GraveStats.astro';
import { getCollection } from 'astro:content';

const allGraves = await getCollection('graves', (g) => g.data.status === 'published');
const graves = allGraves.sort((a, b) => {
  // Sort by death date descending
  return new Date(b.data.death).getTime() - new Date(a.data.death).getTime();
});

const featured = graves[0];
const recentGraves = graves.slice(0, 24);
const subscribed = Astro.url.searchParams.get('subscribed') === '1';
const caseCount = graves.length;
const collections = [
  {
    href: '/collections/most-expensive-startup-failures/',
    title: 'Most Expensive Failures',
    desc: 'The biggest capital bonfires in the graveyard.',
  },
  {
    href: '/collections/killed-by-google/',
    title: 'Killed by Google',
    desc: 'Products buried by Google, strategy shifts, and neglect.',
  },
  {
    href: '/collections/fastest-startup-deaths/',
    title: 'Fastest Deaths',
    desc: 'The shortest-lived products with documented lifespans.',
  },
  {
    href: '/collections/most-overhyped-startup-failures/',
    title: 'Most Overhyped',
    desc: 'When narrative, funding, and reality violently diverged.',
  },
];

const description = `A pixel-art graveyard for ${graves.length} dead tech products. Explore the stories, causes of death, and lessons from failed startups and killed products.`;

const siteUrl = 'https://www.productgrave.net';
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: graves.map((grave, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: grave.data.name,
    url: `${siteUrl}/grave/${grave.slug}/`,
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.productgrave.net/' }
  ],
};
---

<BaseLayout
  title="Product Grave — Dead Tech Products & Failed Startups | Learn from the Dead"
  description={description}
  canonical="https://www.productgrave.net/"
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b-2 border-grave-stone">
    <div class="mx-auto max-w-6xl px-4 pt-16 pb-10 md:pt-24 md:pb-14 text-center">
      <h1 class="text-2xl md:text-4xl text-grave-bone text-shadow-pixel mb-6">
        🪦 PRODUCT GRAVE
        <span class="block text-sm md:text-base text-grave-ghost mt-3 font-sans">A Digital Graveyard for Dead Tech Products &amp; Failed Startups</span>
      </h1>
      <p class="text-base md:text-lg text-grave-ash max-w-2xl mx-auto leading-relaxed mb-2">
        Every dead product has a story. We bury them with honor, analyze their demise,
        and extract lessons for the living.
      </p>
      <p class="text-sm text-grave-ghost mb-8">
        {caseCount} cases · Verdicts open · Join the inquest
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="#graveyard" class="pixel-btn">Enter Graveyard</a>
        <a href="/submit/" class="pixel-btn border-grave-ghost/60 text-grave-ghost hover:bg-grave-ghost hover:text-grave-night">Submit a Death</a>
      </div>
    </div>

    <!-- Decorative stars / particles -->
    <div class="absolute top-8 left-8 text-grave-candle/20 text-lg animate-float">✦</div>
    <div class="absolute top-16 right-12 text-grave-ghost/15 text-sm animate-float" style="animation-delay: 1s;">✦</div>
    <div class="absolute bottom-6 left-1/4 text-grave-blood/10 text-xs animate-float" style="animation-delay: 2s;">✦</div>
  </section>

  {subscribed && (
    <section class="mx-auto max-w-6xl px-4 pt-6">
      <div class="pixel-card p-4 text-center border-grave-ghost/40">
        <p class="text-sm text-grave-ghost">
          ✅ You're on the list. Watch your inbox for the next obituary.
        </p>
      </div>
    </section>
  )}

  <!-- Oracle CTA Banner -->
  <section class="relative border-b-2 border-grave-stone/80 overflow-hidden">
    <!-- Subtle background glow -->
    <div class="absolute inset-0 bg-grave-earth/30" />
    <div class="absolute inset-0 bg-gradient-to-r from-grave-ghost/5 via-transparent to-grave-ghost/5" />
    <!-- Top & bottom accent lines -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-grave-ghost/25 to-transparent" />
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-grave-ghost/15 to-transparent" />
    <!-- Decorative stars -->
    <div class="absolute top-2 right-10 text-grave-ghost/15 text-[10px] animate-float" style="animation-delay: 0.5s;">✦</div>
    <div class="absolute bottom-2 left-10 text-grave-candle/10 text-[8px] animate-float" style="animation-delay: 1.5s;">✦</div>

    <div class="relative mx-auto max-w-6xl px-4 py-4 md:py-5">
      <a href="/validate-idea/" class="flex flex-col md:flex-row items-center justify-between gap-3 md:gap-4 group">
        <div class="flex items-center gap-3 md:gap-4">
          <span class="text-2xl md:text-3xl group-hover:scale-110 transition-transform duration-300">🔮</span>
          <div>
            <h2 class="font-pixel text-[10px] md:text-xs text-grave-bone mb-0.5 group-hover:text-grave-ghost transition-colors">
              WILL YOUR IDEA DIE?
            </h2>
            <p class="text-[11px] md:text-xs text-grave-ash leading-relaxed">
              Ask the Graveyard Oracle — AI pre-mortem analysis based on the Product Grave archive.
            </p>
          </div>
        </div>
        <span class="pixel-btn border-grave-ghost/50 text-grave-ghost hover:bg-grave-ghost hover:text-grave-night text-[10px] shrink-0">
          Get Death Report →
        </span>
      </a>
    </div>
  </section>

  <!-- Today's Featured -->
  {featured && (
    <section class="mx-auto max-w-6xl px-4 py-10">
      <div class="grave-divider mb-6">
        <span class="font-pixel text-xs text-grave-ash whitespace-nowrap">🕯 FRESHLY BURIED</span>
      </div>
      <a href={`/grave/${featured.slug}/`} class="block pixel-card p-6 md:p-8 hover:border-grave-ghost/40 transition-colors">
        <div class="flex flex-col md:flex-row items-start md:items-center gap-6">
          <div class="text-4xl">🪦</div>
          <div class="flex-1">
            <h2 class="font-pixel text-sm md:text-base text-grave-bone mb-2">{featured.data.name}</h2>
            <p class="text-grave-ash text-sm leading-relaxed mb-3">{featured.data.summary}</p>
            <p class="text-xs text-grave-etch font-mono">{featured.data.birth} — {featured.data.death} · {featured.data.industry}</p>
          </div>
          <span class="pixel-btn text-[10px] shrink-0">Read Death Report →</span>
        </div>
      </a>
    </section>
  )}

  <!-- Graveyard Wall -->
  <section id="graveyard" class="mx-auto max-w-6xl px-4 py-10">
    <div class="grave-divider mb-10">
      <span class="font-pixel text-xs text-grave-ash whitespace-nowrap">🪦 THE GRAVEYARD</span>
    </div>

    {recentGraves.length === 0 ? (
      <div class="text-center py-20">
        <p class="font-pixel text-sm text-grave-etch mb-4">The graveyard is empty...</p>
        <p class="text-grave-ash">Be the first to bury a product.</p>
        <a href="/submit/" class="pixel-btn mt-6">Submit a Death</a>
      </div>
    ) : (
      <>
        <ul class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 md:gap-10">
          {recentGraves.map((grave) => (
            <li>
              <TombstoneCard
                slug={grave.slug}
                name={grave.data.name}
                birth={grave.data.birth}
                death={grave.data.death}
                epitaph={grave.data.epitaph}
                causeOfDeath={grave.data.cause_of_death}
                industry={grave.data.industry}
              />
            </li>
          ))}
        </ul>
        {graves.length > 24 && (
          <div class="text-center mt-12">
            <a href="/browse/" class="pixel-btn">
              View All Burials →
            </a>
          </div>
        )}
      </>
    )}
  </section>

  <!-- Collections -->
  <section class="mx-auto max-w-6xl px-4 py-10">
    <div class="grave-divider mb-8">
      <span class="font-pixel text-xs text-grave-ash whitespace-nowrap">🏆 POPULAR COLLECTIONS</span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      {collections.map((collection) => (
        <a href={collection.href} class="pixel-card p-5 hover:border-grave-ghost/40 transition-colors group">
          <h2 class="font-pixel text-xs text-grave-bone group-hover:text-grave-ghost transition-colors mb-3">
            {collection.title}
          </h2>
          <p class="text-xs text-grave-ash leading-relaxed">{collection.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Stats -->
  <GraveStats />

  <!-- Newsletter -->
  <section class="mx-auto max-w-6xl px-4 py-10">
    <div class="pixel-card p-6 md:p-10 max-w-2xl mx-auto text-center">
      <h2 class="font-pixel text-sm text-grave-bone mb-3">📜 THE OBITUARY</h2>
      <p class="text-sm text-grave-ash leading-relaxed mb-6">
        One dead product, delivered to your inbox every week.
        No spam. Just autopsies.
      </p>
      <form action="https://formspree.io/f/mdayjbgq" method="POST" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input type="hidden" name="_subject" value="Newsletter Subscription" />
        <input type="hidden" name="_next" value="https://www.productgrave.net/?subscribed=1" />
        <input
          type="email"
          name="email"
          required
          placeholder="you@example.com"
          class="flex-1 bg-grave-night border-2 border-grave-stone px-4 py-2 text-sm text-grave-bone focus:border-grave-ghost outline-none transition-colors"
        />
        <button type="submit" class="pixel-btn whitespace-nowrap">Subscribe</button>
      </form>
      <p class="text-[10px] text-grave-etch mt-3">Powered by Formspree. Unsubscribe anytime.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-6xl px-4 py-16 text-center">
    <div class="pixel-card p-8 md:p-12 max-w-2xl mx-auto">
      <h2 class="font-pixel text-base text-grave-bone mb-4">Know a Dead Product?</h2>
      <p class="text-grave-ash text-sm leading-relaxed mb-6">
        Help us grow the graveyard. Submit a product death report and contribute to the collective memory of the tech industry.
      </p>
      <a href="/submit/" class="pixel-btn">Submit a Death Report</a>
    </div>
  </section>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>

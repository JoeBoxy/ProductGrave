export async function getStaticPaths() {
  const graves = await getCollection('graves', (g) => g.data.status === 'published');
  const tagSet = new Set<string>();

  graves.forEach((g) => {
    g.data.tags?.forEach((t) => tagSet.add(t));
  });

  return Array.from(tagSet).map((tag) => ({
    params: { tag },
    props: { tag, graves },
  }));
}

const { tag, graves } = Astro.props;

const matchedGraves = graves.filter((g) => g.data.tags?.includes(tag));

const meta = tagDescriptions[tag] || {
  title: `${tag.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase())} — Product Grave`,
  desc: `Explore ${matchedGraves.length} dead tech product${matchedGraves.length === 1 ? '' : 's'} tagged with "${tag}" in the Product Grave digital graveyard.`,
};

const pageTitle = `${meta.title} — Product Grave`;
const canonicalUrl = `https://www.productgrave.net/tag/${tag}/`;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.productgrave.net/' },
    { '@type': 'ListItem', position: 2, name: 'Browse', item: 'https://www.productgrave.net/browse/' },
    { '@type': 'ListItem', position: 3, name: meta.title, item: canonicalUrl },
  ],
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: matchedGraves.map((g, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: g.data.name,
    url: `https://www.productgrave.net/grave/${g.slug}/`,
  })),
};
---

<BaseLayout
  title={pageTitle}
  description={meta.desc}
  canonical={canonicalUrl}
>
  <div class="mx-auto max-w-6xl px-4 py-16 md:py-24">
    <div class="text-center mb-12">
      <nav class="mb-4">
        <a href="/browse/" class="text-xs text-grave-ash hover:text-grave-ghost transition-colors">← Back to Browse</a>
      </nav>
      <h1 class="font-pixel text-xl md:text-2xl text-grave-bone text-shadow-pixel mb-4">
        #{tag.replace(/-/g, ' ')}
      </h1>
      <p class="text-grave-ash max-w-2xl mx-auto leading-relaxed">
        {meta.desc}
      </p>
      <p class="text-xs text-grave-etch mt-3">
        {matchedGraves.length} burial{matchedGraves.length === 1 ? '' : 's'} found
      </p>
    </div>

    {matchedGraves.length === 0 ? (
      <div class="text-center py-20">
        <p class="font-pixel text-sm text-grave-etch mb-4">The graveyard is empty for this tag...</p>
        <a href="/browse/" class="pixel-btn mt-6">Browse All</a>
      </div>
    ) : (
      <ul class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 md:gap-10">
        {matchedGraves.map((grave) => (
          <li>
            <TombstoneCard
              slug={grave.slug}
              name={grave.data.name}
              birth={grave.data.birth}
              death={grave.data.death}
              epitaph={grave.data.epitaph}
              causeOfDeath={grave.data.cause_of_death}
              industry={grave.data.industry}
            />
          </li>
        ))}
      </ul>
    )}
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
</BaseLayout>

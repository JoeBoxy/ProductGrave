---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TombstoneCard from '../../components/tombstone/TombstoneCard.astro';
import { collectionDefinitions, collectionSlugs } from '../../lib/collectionDefinitions';

export async function getStaticPaths() {
  const graves = await getCollection('graves', (g) => g.data.status === 'published');

  return collectionSlugs.map((collection) => ({
    params: { collection },
    props: { collection, graves },
  }));
}

const { collection, graves } = Astro.props;
const definition = collectionDefinitions[collection];
const matchedGraves = graves.filter(definition.filter).sort(definition.sort);
const topGraves = matchedGraves.slice(0, 24);
const canonicalUrl = `https://www.productgrave.net/collections/${collection}/`;

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: definition.title,
  description: definition.seoDescription,
  itemListElement: matchedGraves.map((grave, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: grave.data.name,
    url: `https://www.productgrave.net/grave/${grave.slug}/`,
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.productgrave.net/' },
    { '@type': 'ListItem', position: 2, name: definition.title, item: canonicalUrl },
  ],
};
---

<BaseLayout
  title={`${definition.title} — Product Grave`}
  description={definition.seoDescription}
  canonical={canonicalUrl}
>
  <main class="mx-auto max-w-6xl px-4 py-16 md:py-24">
    <nav class="mb-6">
      <a href="/" class="text-xs text-grave-ash hover:text-grave-ghost transition-colors">← Back to Graveyard</a>
    </nav>

    <header class="pixel-card p-6 md:p-10 mb-10 relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-grave-ghost/10 via-transparent to-grave-blood/10 pointer-events-none" />
      <div class="relative">
        <p class="font-pixel text-[10px] text-grave-ghost mb-3 uppercase tracking-widest">{definition.eyebrow}</p>
        <h1 class="font-pixel text-xl md:text-3xl text-grave-bone text-shadow-pixel mb-4">{definition.title}</h1>
        <p class="text-sm md:text-base text-grave-ash leading-relaxed max-w-3xl">{definition.description}</p>
        <p class="text-xs text-grave-etch mt-4">{matchedGraves.length} burial{matchedGraves.length === 1 ? '' : 's'} in this collection</p>
      </div>
    </header>

    <section class="mb-12">
      <div class="grave-divider mb-8">
        <span class="font-pixel text-xs text-grave-ash whitespace-nowrap">🏆 RANKED BURIALS</span>
      </div>

      <div class="space-y-3">
        {matchedGraves.slice(0, 10).map((grave, index) => (
          <a href={`/grave/${grave.slug}/`} class="pixel-card p-4 flex items-center gap-4 hover:border-grave-ghost/40 transition-colors">
            <span class="font-pixel text-grave-ghost text-xs w-8">#{index + 1}</span>
            <div class="flex-1 min-w-0">
              <p class="font-pixel text-xs text-grave-bone mb-1 truncate">{grave.data.name}</p>
              <p class="text-xs text-grave-ash line-clamp-1">{grave.data.summary}</p>
            </div>
            <span class="font-mono text-xs text-grave-candle shrink-0">{definition.metric(grave)}</span>
          </a>
        ))}
      </div>
    </section>

    <section>
      <div class="grave-divider mb-10">
        <span class="font-pixel text-xs text-grave-ash whitespace-nowrap">🪦 COLLECTION GRAVES</span>
      </div>

      <ul class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 md:gap-10">
        {topGraves.map((grave) => (
          <li>
            <TombstoneCard
              slug={grave.slug}
              name={grave.data.name}
              birth={grave.data.birth}
              death={grave.data.death}
              epitaph={grave.data.epitaph}
              causeOfDeath={grave.data.cause_of_death}
              industry={grave.data.industry}
            />
          </li>
        ))}
      </ul>
    </section>

    <section class="pixel-card p-6 md:p-8 mt-14 text-center">
      <h2 class="font-pixel text-sm text-grave-bone mb-3">Think your idea belongs in this graveyard?</h2>
      <p class="text-sm text-grave-ash leading-relaxed mb-5">
        Run a pre-mortem before the market writes your obituary.
      </p>
      <a href="/validate-idea/" class="pixel-btn">Ask the Oracle →</a>
    </section>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>

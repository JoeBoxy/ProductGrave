---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  ogType?: string;
}

const {
  title,
  description = "A pixel-art graveyard for dead tech products. Learn from the dead.",
  ogImage = "/images/og/default.png",
  canonical,
  ogType = "website",
} = Astro.props;

const siteUrl = "https://www.productgrave.net";
const fullOgImage = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Product Grave",
  "url": siteUrl
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Product Grave",
  "url": siteUrl,
  "logo": `${siteUrl}/images/og/default.png`,
  "sameAs": [
    "https://twitter.com/productgrave",
    "https://github.com/JoeBoxy/ProductGrave"
  ]
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Pixelify+Sans:wght@400;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Product Grave" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical || siteUrl} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />
    <meta name="twitter:site" content="@productgrave" />
    <meta name="twitter:creator" content="@productgrave" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="Product Grave" href="/rss.xml" />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-LV63DMNSW8"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-LV63DMNSW8');
    </script>

    <slot name="head" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)}></script>
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)}></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="sticky top-0 z-50 border-b-2 border-grave-stone bg-grave-night/90 backdrop-blur">
      <div class="mx-auto max-w-6xl px-4 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <span class="text-2xl">🪦</span>
          <span class="font-pixel text-sm md:text-base text-grave-bone group-hover:text-grave-ghost transition-colors">
            PRODUCT GRAVE
          </span>
        </a>
        <nav class="hidden md:flex items-center gap-6">
          <a href="/" class="font-pixel text-[10px] text-grave-ash hover:text-grave-ghost transition-colors uppercase tracking-widest">Graveyard</a>
          <a href="/browse/" class="font-pixel text-[10px] text-grave-ash hover:text-grave-ghost transition-colors uppercase tracking-widest">Browse</a>
          <a href="/stats/" class="font-pixel text-[10px] text-grave-ash hover:text-grave-ghost transition-colors uppercase tracking-widest">Stats</a>
          <a href="/validate-idea/" class="font-pixel text-[10px] text-grave-ash hover:text-grave-ghost transition-colors uppercase tracking-widest">Oracle</a>
          <a href="/submit/" class="font-pixel text-[10px] text-grave-ash hover:text-grave-ghost transition-colors uppercase tracking-widest">Submit</a>
        </nav>
      </div>
      <nav class="md:hidden border-t border-grave-stone/60 px-4 py-3 overflow-x-auto">
        <div class="mx-auto flex max-w-6xl items-center gap-5 whitespace-nowrap">
          <a href="/" class="font-pixel text-[9px] text-grave-ash hover:text-grave-ghost transition-colors uppercase tracking-widest">Graveyard</a>
          <a href="/browse/" class="font-pixel text-[9px] text-grave-ash hover:text-grave-ghost transition-colors uppercase tracking-widest">Browse</a>
          <a href="/stats/" class="font-pixel text-[9px] text-grave-ash hover:text-grave-ghost transition-colors uppercase tracking-widest">Stats</a>
          <a href="/validate-idea/" class="font-pixel text-[9px] text-grave-ghost hover:text-grave-bone transition-colors uppercase tracking-widest">Oracle</a>
          <a href="/submit/" class="font-pixel text-[9px] text-grave-ash hover:text-grave-ghost transition-colors uppercase tracking-widest">Submit</a>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Back to Top -->
    <button
      id="back-to-top"
      class="fixed bottom-6 right-6 z-50 w-10 h-10 border-2 border-grave-stone bg-grave-earth/80 text-grave-ash font-pixel text-sm flex items-center justify-center transition-all duration-300 opacity-0 pointer-events-none hover:border-grave-ghost hover:text-grave-ghost hover:bg-grave-night"
      style="box-shadow: 3px 3px 0px rgba(62, 54, 51, 0.5);"
      aria-label="Back to top"
    >
      ↑
    </button>
    <script is:inline>
      (function() {
        const btn = document.getElementById('back-to-top');
        if (!btn) return;
        function onScroll() {
          if (window.scrollY > 400) {
            btn.classList.remove('opacity-0', 'pointer-events-none');
            btn.classList.add('opacity-100');
          } else {
            btn.classList.add('opacity-0', 'pointer-events-none');
            btn.classList.remove('opacity-100');
          }
        }
        window.addEventListener('scroll', onScroll, { passive: true });
        btn.addEventListener('click', function() {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      })();
    </script>

    <!-- Footer -->
    <footer class="border-t-2 border-grave-stone mt-16">
      <div class="mx-auto max-w-6xl px-4 py-10 flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="text-center md:text-left">
          <p class="font-pixel text-xs text-grave-ash mb-2">PRODUCT GRAVE</p>
          <p class="text-sm text-grave-etch max-w-sm">
            A digital graveyard for dead tech products. Learn from the dead so the living may build better.
          </p>
        </div>
        <div class="flex items-center gap-4">
          <a href="https://twitter.com/productgrave" target="_blank" rel="noopener" class="text-grave-ash hover:text-grave-ghost transition-colors" aria-label="Twitter">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://github.com/JoeBoxy/ProductGrave" target="_blank" rel="noopener" class="text-grave-ash hover:text-grave-ghost transition-colors" aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          </a>
        </div>
      </div>
      <div class="border-t border-grave-stone/50 py-4 text-center">
        <p class="text-xs text-grave-etch">
          © {new Date().getFullYear()} Product Grave. Open source under MIT License.
        </p>
      </div>
    </footer>
  </body>
</html>
